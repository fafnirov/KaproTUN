<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon (Android 8+).

    foreground:   @mipmap/ic_launcher_foreground — orange K-with-ring PNG,
                  content fitted into the 72dp safe zone.
    background:   solid dark from @color/ic_launcher_background.
    monochrome:   alpha-only K silhouette used by Android 13+ "themed icons"
                  (Material You re-tints it to the user's chosen palette).

    Foreground/background sources are produced by
    `scripts/generate_android_assets.py` from the masters in `art/`.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
